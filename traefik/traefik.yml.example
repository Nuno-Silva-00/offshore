api:
  dashboard: true

log:
    level: INFO

providers:
  docker:
    exposedByDefault: false

certificatesResolvers:
  cloudflare:
    acme:
      email:
      storage: acme.json
      dnsChallenge:
        provider: cloudflare
        propagation: 
          delayBeforeChecks: 0

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https

  websecure:
    address: ":443"